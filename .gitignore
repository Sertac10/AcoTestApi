## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userresource
*.userprefs
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Release]/
[Releases]/
x64/
x86/
build/
bld/
[Bin]/
[Obj]/
[bin]/
[obj]/
log.txt
logs.json

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if multiple varieties of Visual Studio are used
#_ReSharper*/

# MSTest test Results
[TestOutcome]/
[TestResults]/

# NUnit
*.VisualState.xml
TestResult.xml

# Rider
.idea/

# DotCover
*.cov

# AxoCover
.axoCover/

# OpenCover
*.opencover.xml

# Visual Studio Code
.vscode/

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# MonoGame Pipeline tool
bin/
obj/

# Package folders
**/packages/
**/node_modules/

# App settings secrets
.env
appsettings.Development.json
